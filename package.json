{
  "name": "challenge-3",
  "version": "1.0.0",
  "description": "EcoTrace is a multi-page Carbon Footprint Awareness Platform built with HTML5, CSS3, and vanilla JavaScript. It includes a calculator, dashboard, Gemini-powered tips, Google Maps action map, challenges, profile, and awareness feed.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.js\" \"*.html\" \"css/**/*.css\"",
    "build": "node build.js",
    "deploy:prod": "node build.js && npx netlify-cli deploy --prod --dir=dist",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@netlify/blobs": "^10.7.9",
    "axe-core": "^4.12.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8"
  }
}
